model Admin {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   AdminRole @default(support)
  status String    @default("active") // 'active', 'suspended'

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  adminLogs          AdminLog[]
  resolvedReports    ModerationReport[]  @relation("Resolver")
  resolvedTickets    ModerationTicket[]  @relation("TicketResolver")
  resolvedPromotions ExternalPromotion[] @relation("AdminExternalPromotions")
  notifications      Notification[]
  notificationReads  NotificationRead[]

  @@map("admins")
}

enum UserRole {
  user
  admin
  vendor
  superadmin
}

enum AdminRole {
  support
  finance
  moderator
  superadmin
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth integrations
  sessions Session[]
  accounts Account[]

  // --- Gift/Platform Profile Fields ---
  displayName   String?    @map("display_name")
  avatarUrl     String?    @map("avatar_url")
  country       String?
  isCreator     Boolean    @default(false) @map("is_creator")
  roles         UserRole[] @default([user])
  userWallet    BigInt     @default(0) @map("user_wallet")
  suspensionEnd DateTime?  @map("suspension_end")

  admin   Admin?
  vendor  Vendor?
  creator Creator?

  // Relations
  campaigns             Campaign[]         @relation("UserCampaigns")
  bankAccounts          BankAccount[]
  transactions          Transaction[]
  favorites             Favorite[]
  sentFlexCards         FlexCard[]         @relation("SentFlexCards")
  receivedFlexCards     FlexCard[]         @relation("ReceivedFlexCards")
  moderationReportsMade ModerationReport[] @relation("Reporter")
  moderationTickets     ModerationTicket[] @relation("TicketReporter")
  directGiftsSent       DirectGift[]       @relation("UserDirectGifts")
  sentUserGiftCards     UserGiftCard[]     @relation("SentUserGiftCards")
  receivedUserGiftCards UserGiftCard[]     @relation("ReceivedUserGiftCards")
  withdrawals           Withdrawal[]

  notifications     Notification[]
  notificationReads NotificationRead[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

model Campaign {
  id                       String    @id @default(uuid())
  userId                   String    @map("user_id")
  user                     User      @relation("UserCampaigns", fields: [userId], references: [id], onDelete: Cascade)
  category                 String
  title                    String
  description              String?
  goalAmount               Decimal?  @map("goal_amount")
  minAmount                Decimal?  @map("min_amount")
  currentAmount            Decimal   @default(0) @map("current_amount")
  endDate                  DateTime? @map("end_date")
  imageUrl                 String?   @map("image_url")
  coverImage               String?   @map("cover_image")
  images                   String[]  @default([])
  visibility               String    @default("public")
  contributorsSeeEachOther Boolean   @default(true) @map("contributors_see_each_other")
  status                   String    @default("active")
  statusReason             String?   @map("status_reason")
  pausedBy                 String?   @map("paused_by")
  isFlagged                Boolean   @default(false) @map("is_flagged")
  flagReason               String?   @map("flag_reason")
  flaggedAt                DateTime? @map("flagged_at")
  flaggedBy                String?   @map("flagged_by")
  campaignShortId          String?   @unique @map("campaign_short_id")
  campaignSlug             String?   @map("campaign_slug")

  // Claimable logic
  claimableType          String?     @map("claimable_type")
  claimableGiftId        Int?        @map("claimable_gift_id")
  product                VendorGift? @relation("CampaignProduct", fields: [claimableGiftId], references: [id], onDelete: SetNull)
  giftCardId             Int?        @map("gift_card_id")
  giftCard               GiftCard?   @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  claimableRecipientType String?     @map("claimable_recipient_type")
  recipientEmail         String?     @map("recipient_email")
  senderEmail            String?     @map("sender_email")
  paymentReference       String?     @map("payment_reference")
  currency               String      @default("NGN")
  giftCode               String?     @map("gift_code")
  message                String?

  // V2 WhatsApp/Delivery
  deliveryMethod       String? @default("email") @map("delivery_method")
  recipientPhone       String? @map("recipient_phone")
  recipientCountryCode String? @map("recipient_country_code")
  whatsappFee          Decimal @default(0) @map("whatsapp_fee")
  senderName           String? @map("sender_name")

  withdrawnAmount Decimal @default(0) @map("withdrawn_amount")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contributions Contribution[]
  withdrawals   CampaignWithdrawal[]
  transactions  Transaction[]

  @@map("campaigns")
}

model CampaignWithdrawal {
  id            String      @id @default(uuid())
  campaignId    String      @map("campaign_id")
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  amount        Decimal
  currency      String      @default("NGN")
  transactionId String      @unique @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("campaign_withdrawals")
}

model Contribution {
  id            String       @id @default(uuid())
  campaignId    String       @map("campaign_id")
  campaign      Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  transactionId String?      @unique @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  amount        Decimal
  currency      String       @default("NGN")
  donorName     String       @map("donor_name")
  donorEmail    String?      @map("donor_email")
  message       String?
  isAnonymous   Boolean      @default(false) @map("is_anonymous")
  hideAmount    Boolean      @default(false) @map("hide_amount")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("contributions")
}

model Creator {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  username      String  @unique
  bio           String?
  bannerUrl     String? @map("banner_url")
  socialLinks   Json?   @default("{}") @map("social_links")
  themeSettings Json?   @default("{}") @map("theme_settings")

  wallet BigInt @default(0)
  status String @default("active") // active, suspended

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  supportReceived CreatorSupport[] @relation("CreatorSupportRecipient")

  @@map("creators")
}

model DirectGift {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  user        User    @relation("UserDirectGifts", fields: [userId], references: [id], onDelete: Cascade)
  category    String
  title       String
  description String?
  amount      Decimal
  currency    String  @default("NGN")
  status      String  @default("active") // active, claimed, redeemed, failed

  // Claimable logic
  claimableType          String?     @map("claimable_type") // null for some legacy? Usually 'money' or 'gift-card'
  claimableGiftId        Int?        @map("claimable_gift_id")
  product                VendorGift? @relation("DirectGiftProduct", fields: [claimableGiftId], references: [id], onDelete: SetNull)
  giftCardId             Int?        @map("gift_card_id")
  giftCard               GiftCard?   @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  claimableRecipientType String?     @map("claimable_recipient_type")
  recipientEmail         String?     @map("recipient_email")
  senderEmail            String?     @map("sender_email")
  paymentReference       String?     @map("payment_reference")
  giftCode               String?     @unique @map("gift_code")

  // Custom/Voucher redemption
  redeemedAt         DateTime? @map("redeemed_at")
  redeemedByVendorId String?   @map("redeemed_by_vendor_id")
  redeemedByVendor   Vendor?   @relation("DirectGiftRedeemedByVendor", fields: [redeemedByVendorId], references: [id], onDelete: SetNull)
  vendorRating       Int?      @map("vendor_rating")
  message            String?

  // V2 WhatsApp/Delivery
  deliveryMethod       String? @default("email") @map("delivery_method")
  recipientPhone       String? @map("recipient_phone")
  recipientCountryCode String? @map("recipient_country_code")
  whatsappFee          Decimal @default(0) @map("whatsapp_fee")
  senderName           String? @map("sender_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("direct_gifts")
}

model FeaturedAd {
  id               Int        @id @default(autoincrement())
  vendorId         String     @map("vendor_id")
  vendor           Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorGiftId     Int        @map("vendor_gift_id")
  product          VendorGift @relation("GiftFeaturedAds", fields: [vendorGiftId], references: [id], onDelete: Cascade)
  country          String
  slotNumber       Int        @map("slot_number")
  startDate        DateTime   @map("start_date")
  endDate          DateTime   @map("end_date")
  status           String     @default("active") // 'scheduled', 'active', 'expired'
  amountPaid       Decimal    @map("amount_paid")
  currency         String     @default("NGN")
  paymentReference String?    @map("payment_reference")

  // Stats
  views  Int @default(0)
  clicks Int @default(0)

  transactionId String?      @unique @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("featured_ads")
}

model SponsoredAd {
  id               Int        @id @default(autoincrement())
  vendorId         String     @map("vendor_id")
  vendor           Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorGiftId     Int        @map("vendor_gift_id")
  product          VendorGift @relation("GiftSponsoredAds", fields: [vendorGiftId], references: [id], onDelete: Cascade)
  country          String
  budget           Decimal
  remainingBudget  Decimal    @map("remaining_budget")
  costPerClick     Decimal    @map("cost_per_click")
  currency         String     @default("NGN")
  startDate        DateTime   @default(now()) @map("start_date")
  endDate          DateTime?  @map("end_date") // Optional if running until budget ends
  status           String     @default("active") // 'active', 'paused', 'completed'
  paymentReference String?    @map("payment_reference")

  // Stats
  views  Int @default(0)
  clicks Int @default(0)

  transactionId String?      @unique @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sponsored_ads")
}

model ExternalPromotion {
  id          Int       @id @default(autoincrement())
  adminId     String
  admin       Admin     @relation("AdminExternalPromotions", fields: [adminId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
  link        String?
  placement   String // 'banner', 'hero', 'sidebar'
  startDate   DateTime  @default(now())
  endDate     DateTime?
  status      String    @default("active")

  views  Int @default(0)
  clicks Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("external_promotions")
}

model FeaturedItem {
  id          Int     @id @default(autoincrement())
  title       String?
  description String?
  imageUrl    String?
  link        String?
  type        String // 'banner', 'collection', 'highlight'
  order       Int     @default(0)
  isActive    Boolean @default(true)
  metadata    Json?   @default("{}")

  createdAt DateTime @default(now())

  @@map("featured_items")
}

model Transaction {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  vendorId    String?   @map("vendor_id")
  vendor      Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  campaignId  String?   @map("campaign_id")
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  amount      BigInt // In smallest currency unit (kobo/cents)
  currency    String    @default("NGN")
  type        String // 'campaign_contribution', 'creator_support', 'withdrawal', 'payout', 'fee', 'receipt', 'gift_redemption', 'gift_sent', 'flex_card_redemption', 'flex_card', 'platform_credit_conversion'
  status      String    @default("pending") // 'pending', 'success', 'failed'
  reference   String?   @unique
  description String?
  metadata    Json?     @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  creatorSupport     CreatorSupport?
  contribution       Contribution?
  withdrawal         Withdrawal?
  featuredAd         FeaturedAd?
  sponsoredAd        SponsoredAd?
  campaignWithdrawal CampaignWithdrawal?

  @@map("transactions")
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId      String?  @map("vendor_id")
  vendor        Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bankName      String   @map("bank_name")
  bankCode      String   @map("bank_code")
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  recipientCode String?  @map("recipient_code")
  currency      String   @default("NGN")
  country       String   @default("Nigeria")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  withdrawals Withdrawal[]

  @@map("bank_accounts")
}

model Withdrawal {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId        String?      @map("vendor_id")
  vendor          Vendor?      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bankAccountId   String       @map("bank_account_id")
  bankAccount     BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  amount          Decimal
  currency        String       @default("NGN")
  status          String       @default("pending") // 'pending', 'approved', 'rejected', 'completed'
  reference       String?      @unique
  rejectionReason String?      @map("rejection_reason")
  transactionId   String?      @unique @map("transaction_id")
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("withdrawals")
}

model FlexCard {
  id             Int       @id @default(autoincrement())
  userId         String?
  recipient      User?     @relation("ReceivedFlexCards", fields: [userId], references: [id], onDelete: SetNull)
  senderId       String?
  sender         User?     @relation("SentFlexCards", fields: [senderId], references: [id], onDelete: SetNull)
  initialAmount  Decimal
  currentBalance Decimal
  currency       String    @default("NGN")
  code           String    @unique
  claimToken     String?   @unique
  status         String    @default("active")
  senderName     String?
  recipientEmail String?
  recipientPhone String?
  deliveryMethod String    @default("email")
  message        String?
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions FlexCardTransaction[]

  @@map("flex_cards")
}

model FlexCardTransaction {
  id           Int      @id @default(autoincrement())
  flexCardId   Int
  flexCard     FlexCard @relation(fields: [flexCardId], references: [id], onDelete: Cascade)
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount       Decimal
  balanceAfter Decimal
  description  String?
  createdAt    DateTime @default(now())

  @@map("flex_card_transactions")
}

model GiftCard {
  id                Int     @id @default(autoincrement())
  name              String
  slug              String  @unique
  description       String?
  category          String // food, fashion, electronics, shopping, lifestyle, everyday, occasions, brand, gadgets, location
  icon              String? // Material icon name
  colorFrom         String? @map("color_from") // gradient start hex
  colorTo           String? @map("color_to") // gradient end hex
  imageUrl          String? @map("image_url")
  amountOptions     Json    @default("[]") // e.g. [1000, 3000, 5000, 10000]
  allowCustomAmount Boolean @default(true) @map("allow_custom_amount")
  minAmount         Decimal @default(500) @map("min_amount")
  maxAmount         Decimal @default(500000) @map("max_amount")
  currency          String  @default("NGN")
  serviceFeePercent Decimal @default(4) @map("service_fee_percent")
  country           String? // null = available everywhere
  status            String  @default("draft") // draft, active, paused, archived
  isFlexCard        Boolean @default(false) @map("is_flex_card") // true for the special Flex Card entry
  usageDescription  String? @map("usage_description") // "Redeemable at food vendors"
  metadata          Json?   @default("{}")
  displayOrder      Int     @default(0) @map("display_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendors       VendorAcceptedGiftCard[]
  directGifts   DirectGift[]
  campaigns     Campaign[]
  userGiftCards UserGiftCard[]

  @@map("gift_cards")
}

model VendorAcceptedGiftCard {
  id         Int      @id @default(autoincrement())
  vendorId   String   @map("vendor_id")
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  giftCardId Int      @map("gift_card_id")
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([vendorId, giftCardId])
  @@map("vendor_accepted_gift_cards")
}

model ModerationReport {
  id               String  @id @default(uuid())
  targetId         String
  targetType       String // 'campaign', 'user', 'vendor', 'gift'
  targetName       String?
  reporterId       String?
  reporter         User?   @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reporterUsername String  @default("anonymous")
  reason           String
  status           String  @default("pending") // 'pending', 'resolved', 'dismissed'
  resolutionNotes  String?
  resolvedById     String?
  resolver         Admin?  @relation("Resolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("moderation_reports")
}

model ModerationTicket {
  id           String  @id @default(uuid())
  reporterId   String
  reporter     User    @relation("TicketReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  subject      String
  description  String
  status       String  @default("open") // 'open', 'in_progress', 'resolved', 'closed'
  priority     String  @default("medium") // 'low', 'medium', 'high'
  resolvedById String?
  resolver     Admin?  @relation("TicketResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("moderation_tickets")
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  createdAt DateTime @default(now())

  @@map("admin_logs")
}

model CreatorSupport {
  id            String       @id @default(uuid())
  creatorId     String       @map("creator_id")
  creator       Creator      @relation("CreatorSupportRecipient", fields: [creatorId], references: [id], onDelete: Cascade)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  amount        Decimal
  currency      String       @default("NGN")
  donorName     String
  donorEmail    String?
  message       String?
  isAnonymous   Boolean      @default(false)
  hideAmount    Boolean      @default(false)
  giftId        Int?
  giftName      String?
  vendorRating  Int?

  createdAt DateTime @default(now())

  @@map("creator_support")
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     String?  @map("user_id")
  type       String
  title      String
  message    String
  data       Json     @default("{}")
  isGlobal   Boolean  @default(false) @map("is_global")
  targetRole String?  @map("target_role")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId String?            @map("vendor_id")
  vendor   Vendor?            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  adminId  String?            @map("admin_id")
  admin    Admin?             @relation(fields: [adminId], references: [id], onDelete: Cascade)
  reads    NotificationRead[]

  @@map("notifications")
}

model NotificationRead {
  id             Int      @id @default(autoincrement())
  notificationId Int      @map("notification_id")
  userId         String?  @map("user_id")
  vendorId       String?  @map("vendor_id")
  createdAt      DateTime @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  admin        Admin?       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  adminId String? @map("admin_id")

  @@unique([notificationId, userId])
  @@unique([notificationId, vendorId])
  @@unique([notificationId, adminId])
  @@map("notification_reads")
}

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
  output          = "../../src/generated/prisma"
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value Json

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model CountryConfig {
  id             String @id @default(uuid())
  countryName    String @unique @map("country_name")
  countryCode    String @unique @map("country_code") // ISO 2-letter code: NG, GH, KE
  currency       String // ISO currency code: NGN, GHS, KES
  currencySymbol String @map("currency_symbol") // ₦, GH₵, KSh
  flag           String @default("🏳️")

  // Financial rules
  transactionFeePercent Decimal @default(4) @map("transaction_fee_percent")
  withdrawalFeeFlat     Decimal @default(0) @map("withdrawal_fee_flat")
  minWithdrawal         Decimal @default(0) @map("min_withdrawal")
  maxWithdrawal         Decimal @default(0) @map("max_withdrawal")

  // Feature flags
  features Json  @default("{\"creatorSupport\": true, \"vendorShop\": true, \"campaigns\": true, \"flexCard\": true, \"directGift\": true, \"withdrawals\": true, \"accessRules\": {}}") @map("features")
  adConfig Json? @default("{}") @map("ad_config")

  // Status
  isEnabled Boolean @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("country_configs")
}

model UserGiftCard {
  id             Int       @id @default(autoincrement())
  userId         String?
  recipient      User?     @relation("ReceivedUserGiftCards", fields: [userId], references: [id], onDelete: SetNull)
  senderId       String?
  sender         User?     @relation("SentUserGiftCards", fields: [senderId], references: [id], onDelete: SetNull)
  giftCardId     Int
  giftCard       GiftCard  @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  initialAmount  Decimal
  currentBalance Decimal
  currency       String    @default("NGN")
  code           String    @unique
  claimToken     String?   @unique
  status         String    @default("active")
  senderName     String?
  recipientEmail String?
  recipientPhone String?
  deliveryMethod String    @default("email")
  message        String?
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions UserGiftCardTransaction[]

  @@map("user_gift_cards")
}

model UserGiftCardTransaction {
  id             Int          @id @default(autoincrement())
  userGiftCardId Int
  userGiftCard   UserGiftCard @relation(fields: [userGiftCardId], references: [id], onDelete: Cascade)
  vendorId       String
  vendor         Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount         Decimal
  balanceAfter   Decimal
  description    String?
  createdAt      DateTime     @default(now())

  @@map("user_gift_card_transactions")
}

model Vendor {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName        String  @map("business_name")
  businessDescription String? @map("business_description")
  businessSlug        String  @unique @map("business_slug")
  businessLogoUrl     String? @map("business_logo_url")
  socialLinks         Json?   @default("{}") @map("social_links")

  // Address fields
  streetAddress String? @map("street_address")
  city          String? @map("city")
  state         String? @map("state")
  country       String? @map("country")
  postalCode    String? @map("postal_code")

  // Status & Metadata
  status     String   @default("pending") // 'pending', 'approved', 'rejected'
  isVerified Boolean  @default(false) @map("is_verified")
  categories String[] @default([]) @map("categories")
  wallet     BigInt   @default(0) @map("vendor_wallet")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  vendorGifts              VendorGift[]
  featuredAds              FeaturedAd[]
  sponsoredAds             SponsoredAd[]
  tagRequests              TagRequest[]
  acceptedCards            VendorAcceptedGiftCard[]
  bankAccounts             BankAccount[]
  withdrawals              Withdrawal[]
  transactions             Transaction[]
  notifications            Notification[]
  flexCardTransactions     FlexCardTransaction[]
  userGiftCardTransactions UserGiftCardTransaction[]
  redeemedDirectGifts      DirectGift[]              @relation("DirectGiftRedeemedByVendor")
  notificationReads        NotificationRead[]

  @@map("vendors")
}

model VendorGift {
  id             Int                 @id @default(autoincrement())
  vendorId       String              @map("vendor_id")
  vendor         Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name           String
  slug           String?
  productShortId String?             @unique @map("product_short_id")
  price          Decimal
  description    String?
  imageUrl       String?             @map("image_url")
  categoryId     Int?                @map("category_id")
  categoryRel    ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId  Int?                @map("subcategory_id")
  subcategoryRel ProductSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  category    String? // Legacy category field, will be deprecated
  tags        String[]        @default([]) // Legacy tags field, will be deprecated
  productTags VendorGiftTag[]

  type   String @default("digital") // 'digital' or 'physical'
  status String @default("active") // 'draft', 'active', 'suspended', 'rejected'

  // V2 specific
  stockQuantity Int?     @map("stock_quantity")
  images        String[] @default([])

  // Ranking & Engagement
  viewsCount       Int      @default(0) @map("views_count")
  clicksCount      Int      @default(0) @map("clicks_count")
  salesCount       Int      @default(0) @map("sales_count")
  rankingScore     Float    @default(0) @map("ranking_score")
  lastEngagementAt DateTime @default(now()) @map("last_engagement_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  giftImages   VendorGiftImage[]
  favorites    Favorite[]
  featuredAds  FeaturedAd[]      @relation("GiftFeaturedAds")
  sponsoredAds SponsoredAd[]     @relation("GiftSponsoredAds")
  campaigns    Campaign[]        @relation("CampaignProduct")
  directGifts  DirectGift[]      @relation("DirectGiftProduct")

  @@map("vendor_gifts")
}

model VendorGiftImage {
  id        Int        @id @default(autoincrement())
  giftId    Int        @map("gift_id")
  gift      VendorGift @relation(fields: [giftId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("vendor_gift_images")
}

model Favorite {
  id           Int        @id @default(autoincrement())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorGiftId Int        @map("vendor_gift_id")
  vendorGift   VendorGift @relation(fields: [vendorGiftId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, vendorGiftId], name: "userId_vendorGiftId")
  @@map("favorites")
}

model Rating {
  id         Int      @id @default(autoincrement())
  targetId   String   @map("target_id") // Can be vendorId or campaignId
  targetType String   @map("target_type") // 'vendor', 'campaign'
  userId     String   @map("user_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("ratings")
}

model ProductCategory {
  id            Int                  @id @default(autoincrement())
  name          String               @unique
  slug          String               @unique
  subcategories ProductSubcategory[]
  vendorGifts   VendorGift[]
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@map("product_categories")
}

model ProductSubcategory {
  id          Int             @id @default(autoincrement())
  categoryId  Int             @map("category_id")
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  tags        ProductTag[]
  vendorGifts VendorGift[]
  tagRequests TagRequest[]    @relation("SubcategoryTagRequests")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([categoryId, name])
  @@unique([categoryId, slug])
  @@map("product_subcategories")
}

model ProductTag {
  id            Int                @id @default(autoincrement())
  subcategoryId Int                @map("subcategory_id")
  subcategory   ProductSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  vendorGifts   VendorGiftTag[]
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@unique([subcategoryId, name])
  @@unique([subcategoryId, slug])
  @@map("product_tags")
}

model VendorGiftTag {
  giftId Int        @map("gift_id")
  tagId  Int        @map("tag_id")
  gift   VendorGift @relation(fields: [giftId], references: [id], onDelete: Cascade)
  tag    ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([giftId, tagId])
  @@map("vendor_gift_tags")
}

model TagRequest {
  id            Int                @id @default(autoincrement())
  vendorId      String             @map("vendor_id")
  vendor        Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  subcategoryId Int                @map("subcategory_id")
  subcategory   ProductSubcategory @relation(name: "SubcategoryTagRequests", fields: [subcategoryId], references: [id], onDelete: Cascade)
  tagName       String             @map("tag_name")
  status        String             @default("pending") // 'pending', 'approved', 'rejected'
  adminNotes    String?            @map("admin_notes")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("tag_requests")
}
