model Vendor {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessName        String   @map("business_name")
  businessDescription String?  @map("business_description")
  businessSlug        String   @unique @map("business_slug")
  businessLogoUrl     String?  @map("business_logo_url")
  socialLinks         Json?    @default("{}") @map("social_links")

  // Address fields
  streetAddress       String?  @map("street_address")
  city                String?  @map("city")
  state               String?  @map("state")
  country             String?  @map("country")
  postalCode          String?  @map("postal_code")

  // Status & Metadata
  status              String   @default("pending") // 'pending', 'approved', 'rejected'
  isVerified          Boolean  @default(false)     @map("is_verified")
  categories          String[] @default([])        @map("categories")
  wallet              BigInt   @default(0)         @map("vendor_wallet")

  createdAt           DateTime @default(now())     @map("created_at")
  updatedAt           DateTime @updatedAt          @map("updated_at")

  // Relations
  acceptedCards            VendorAcceptedGiftCard[]
  bankAccounts             BankAccount[]
  withdrawals              Withdrawal[]
  transactions             Transaction[]
  notifications            Notification[]
  flexCardTransactions     FlexCardTransaction[]
  userGiftCardTransactions UserGiftCardTransaction[]
  redeemedDirectGifts      DirectGift[]              @relation("DirectGiftRedeemedByVendor")
  notificationReads        NotificationRead[]

  @@map("vendors")
}

model Rating {
  id         Int      @id @default(autoincrement())
  targetId   String   @map("target_id") // Can be vendorId or campaignId
  targetType String   @map("target_type") // 'vendor', 'campaign'
  userId     String   @map("user_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("ratings")
}
