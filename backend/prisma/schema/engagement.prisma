model Favorite {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftCardId Int      @map("gift_card_id")
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, giftCardId])
  @@map("favorites")
}

model ExternalPromotion {
  id          Int       @id @default(autoincrement())
  adminId     String
  admin       Admin     @relation("AdminExternalPromotions", fields: [adminId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
  link        String?
  placement   String // 'banner', 'hero', 'sidebar'
  startDate   DateTime  @default(now())
  endDate     DateTime?
  status      String    @default("active")

  views  Int @default(0)
  clicks Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("external_promotions")
}

model FeaturedItem {
  id          Int     @id @default(autoincrement())
  title       String?
  description String?
  imageUrl    String?
  link        String?
  type        String // 'banner', 'collection', 'highlight'
  order       Int     @default(0)
  isActive    Boolean @default(true)
  metadata    Json?   @default("{}")

  createdAt DateTime @default(now())

  @@map("featured_items")
}

