model Transaction {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignId  String?   @map("campaign_id")
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  amount      BigInt // In smallest currency unit (kobo/cents)
  currency    String    @default("NGN")
  type        String // 'campaign_contribution', 'creator_support', 'withdrawal', 'payout', 'fee', 'receipt', 'gift_redemption', 'gift_sent', 'flex_card_redemption', 'flex_card', 'platform_credit_conversion'
  status      String    @default("pending") // 'pending', 'success', 'failed'
  reference   String?   @unique
  description String?
  metadata    Json?     @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  creatorSupport CreatorSupport?
  contribution   Contribution?
  withdrawal     Withdrawal?
  promotion      Promotion?

  @@map("transactions")
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankName      String   @map("bank_name")
  bankCode      String   @map("bank_code")
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  recipientCode String?  @map("recipient_code")
  currency      String   @default("NGN")
  country       String   @default("Nigeria")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  withdrawals Withdrawal[]

  @@map("bank_accounts")
}

model Withdrawal {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccountId   String       @map("bank_account_id")
  bankAccount     BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  amount          Decimal
  currency        String       @default("NGN")
  status          String       @default("pending") // 'pending', 'approved', 'rejected', 'completed'
  reference       String?      @unique
  rejectionReason String?      @map("rejection_reason")
  transactionId   String?      @unique @map("transaction_id")
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("withdrawals")
}
